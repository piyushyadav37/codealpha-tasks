<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Calculator</title>
<style>
  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #100f0c;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  .card {
    background: #1e1d19;
    border-radius: 20px;
    padding: 20px;
    border: 0.5px solid #33322c;
    width: 320px;
  }
  #display {
    background: #1b1a17;
    color: #fff;
    border-radius: 14px;
    padding: 28px 20px 20px;
    margin-bottom: 16px;
    text-align: right;
    overflow: hidden;
  }
  #expr {
    font-size: 14px;
    color: #9a988f;
    min-height: 18px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #result {
    font-size: 40px;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 4px;
  }
  #pad {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  button {
    height: 56px;
    border-radius: 14px;
    border: none;
    font-size: 20px;
    font-weight: 500;
    cursor: pointer;
    transition: transform 0.08s ease, background 0.15s ease;
  }
  button:active { transform: scale(0.94); }
  .num   { background: #2a2924; color: #f2f0ea; }
  .num:hover   { background: #37352e; }
  .op    { background: #3c3a33; color: #e7c56a; }
  .op:hover    { background: #48453c; }
  .fn    { background: #c9c5b8; color: #1b1a17; }
  .fn:hover    { background: #d8d4c6; }
  .eq    { background: #e7c56a; color: #1b1a17; }
  .eq:hover    { background: #f0d27c; }
  .span2 { grid-column: span 2; }
</style>
</head>
<body>

<div class="card">
  <div id="display">
    <div id="expr"></div>
    <div id="result">0</div>
  </div>
  <div id="pad">
    <button class="fn span2" data-action="clear">ac</button>
    <button class="fn" data-action="del">del</button>
    <button class="op" data-op="/">÷</button>

    <button class="num">7</button>
    <button class="num">8</button>
    <button class="num">9</button>
    <button class="op" data-op="*">×</button>

    <button class="num">4</button>
    <button class="num">5</button>
    <button class="num">6</button>
    <button class="op" data-op="-">−</button>

    <button class="num">1</button>
    <button class="num">2</button>
    <button class="num">3</button>
    <button class="op" data-op="+">+</button>

    <button class="num span2">0</button>
    <button class="num">.</button>
    <button class="eq">=</button>
  </div>
</div>

<script>
(function(){
  var expr = "";
  var justEvaluated = false;
  var exprEl = document.getElementById('expr');
  var resultEl = document.getElementById('result');
  var pad = document.getElementById('pad');

  function formatNum(n){
    if (!isFinite(n)) return 'error';
    var s = n.toString();
    if (s.length > 12) {
      s = parseFloat(n.toPrecision(10)).toString();
    }
    return s;
  }

  function safeEval(str){
    if (!/^[0-9+\-*/.\s]+$/.test(str)) return null;
    try {
      var val = Function('"use strict"; return (' + str + ')')();
      return typeof val === 'number' ? val : null;
    } catch(e) { return null; }
  }

  function render(){
    exprEl.textContent = expr.replace(/\*/g,'×').replace(/\//g,'÷');
    var val = safeEval(expr);
    resultEl.textContent = expr === '' ? '0' : (val === null ? '' : formatNum(val));
  }

  function pressNum(label){
    if (justEvaluated){ expr = ''; justEvaluated = false; }
    if (label === '.'){
      var parts = expr.split(/[+\-*/]/);
      var current = parts[parts.length - 1];
      if (current.includes('.')) return;
      if (current === '') expr += '0';
    }
    expr += label;
    render();
  }

  function pressOp(op){
    if (expr === '' && op !== '-') return;
    var last = expr.slice(-1);
    if ('+-*/'.includes(last)) expr = expr.slice(0, -1);
    expr += op;
    justEvaluated = false;
    render();
  }

  function pressEq(){
    var val = safeEval(expr);
    if (val !== null){
      expr = formatNum(val);
      justEvaluated = true;
    }
    render();
  }

  function pressFn(action){
    if (action === 'clear'){ expr = ''; justEvaluated = false; }
    if (action === 'del'){ expr = expr.slice(0, -1); justEvaluated = false; }
    render();
  }

  pad.addEventListener('click', function(e){
    var btn = e.target.closest('button');
    if (!btn) return;
    if (btn.classList.contains('num')) pressNum(btn.textContent);
    else if (btn.classList.contains('op')) pressOp(btn.dataset.op);
    else if (btn.classList.contains('eq')) pressEq();
    else if (btn.classList.contains('fn')) pressFn(btn.dataset.action);
  });

  document.addEventListener('keydown', function(e){
    var k = e.key;
    if (/[0-9.]/.test(k)) pressNum(k);
    else if (['+','-','*','/'].includes(k)) pressOp(k);
    else if (k === 'Enter' || k === '=') pressEq();
    else if (k === 'Backspace') pressFn('del');
    else if (k === 'Escape') pressFn('clear');
  });

  render();
})();
</script>

</body>
</html>